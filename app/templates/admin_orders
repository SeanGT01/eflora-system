{% extends "layout.html" %}

{% block title %}Orders Management - E-FLOWERS{% endblock %}

{% block page_title %}Orders Management{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h3 style="font-weight: 600; color: var(--text); margin-bottom: 0.5rem;">Manage All Orders</h3>
        <p style="color: var(--text-light);">View, track, and manage orders from all stores</p>
    </div>
    <div style="display: flex; gap: 1rem;">
        <button class="btn btn-outline" onclick="exportOrders()">
            <i class="ri-download-line"></i>
            Export
        </button>
        <button class="btn btn-primary" onclick="refreshOrders()">
            <i class="ri-refresh-line"></i>
            Refresh
        </button>
    </div>
</div>

<!-- Filters & Stats -->
<div class="content-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 2rem;">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Total Orders</h3>
            <div class="card-icon">
                <i class="ri-shopping-bag-line"></i>
            </div>
        </div>
        <div class="stat-number" id="totalOrders">0</div>
        <p class="stat-label">All time</p>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Today's Orders</h3>
            <div class="card-icon">
                <i class="ri-calendar-line"></i>
            </div>
        </div>
        <div class="stat-number" id="todayOrders">0</div>
        <p class="stat-label">Placed today</p>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Pending</h3>
            <div class="card-icon">
                <i class="ri-time-line"></i>
            </div>
        </div>
        <div class="stat-number" id="pendingOrders">0</div>
        <p class="stat-label">Awaiting processing</p>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Revenue</h3>
            <div class="card-icon">
                <i class="ri-money-dollar-circle-line"></i>
            </div>
        </div>
        <div class="stat-number" id="totalRevenue">₱0</div>
        <p class="stat-label">This month</p>
    </div>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom: 2rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <div class="form-group">
            <label class="form-label">Store</label>
            <select class="form-control" id="storeFilter">
                <option value="">All Stores</option>
                <!-- Will be populated by JavaScript -->
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-control" id="statusFilter">
                <option value="">All Status</option>
                <option value="pending">Pending</option>
                <option value="accepted">Accepted</option>
                <option value="preparing">Preparing</option>
                <option value="on_delivery">On Delivery</option>
                <option value="delivered">Delivered</option>
                <option value="canceled">Canceled</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Date Range</label>
            <select class="form-control" id="dateFilter">
                <option value="today">Today</option>
                <option value="yesterday">Yesterday</option>
                <option value="week">This Week</option>
                <option value="month" selected>This Month</option>
                <option value="all">All Time</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Search</label>
            <div style="display: flex; gap: 0.5rem;">
                <input type="text" class="form-control" id="searchInput" placeholder="Search order ID or customer...">
                <button class="btn btn-primary" onclick="searchOrders()" style="padding: 0.875rem 1rem;">
                    <i class="ri-search-line"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Orders Table -->
<div class="chart-container">
    <div class="chart-header">
        <h3 class="chart-title">All Orders</h3>
        <div style="display: flex; gap: 0.5rem;">
            <button class="btn btn-outline" onclick="clearFilters()" style="padding: 0.5rem 1rem;">
                Clear Filters
            </button>
        </div>
    </div>
    <div class="table-container">
        <table class="table" id="ordersTable">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Store</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="ordersTableBody">
                <!-- Orders will be loaded here by JavaScript -->
                <tr id="loadingRow">
                    <td colspan="9" style="text-align: center; padding: 3rem;">
                        <div class="loading-spinner" style="margin: 0 auto;"></div>
                        <p style="margin-top: 1rem; color: var(--text-light);">Loading orders...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div style="display: flex; justify-content: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(182, 110, 121, 0.1);">
        <div style="display: flex; gap: 0.5rem; align-items: center;">
            <button class="btn btn-outline" id="prevPage" style="padding: 0.5rem 1rem;" disabled>
                <i class="ri-arrow-left-s-line"></i>
            </button>
            <span style="font-size: 14px; color: var(--text);">
                Page <span id="currentPage">1</span> of <span id="totalPages">1</span>
            </span>
            <button class="btn btn-outline" id="nextPage" style="padding: 0.5rem 1rem;" disabled>
                <i class="ri-arrow-right-s-line"></i>
            </button>
            <select class="form-control" id="pageSize" style="width: auto; padding: 0.5rem; font-size: 14px;">
                <option value="10">10 per page</option>
                <option value="25" selected>25 per page</option>
                <option value="50">50 per page</option>
                <option value="100">100 per page</option>
            </select>
        </div>
    </div>
</div>

<!-- Order Details Modal -->
<div id="orderDetailsModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); z-index: 2000; align-items: center; justify-content: center; padding: 1rem;">
    <div style="background: var(--surface); border-radius: var(--radius-xl); padding: 2rem; width: 90%; max-width: 800px; max-height: 90vh; overflow-y: auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="font-weight: 600; color: var(--text);">Order Details</h3>
            <button onclick="closeOrderDetails()" style="background: none; border: none; font-size: 24px; color: var(--text-light); cursor: pointer;">
                <i class="ri-close-line"></i>
            </button>
        </div>
        
        <div id="orderDetailsContent">
            <!-- Order details will be loaded here -->
        </div>
    </div>
</div>
{% endblock %}

