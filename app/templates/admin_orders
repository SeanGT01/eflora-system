            amount: 3200,
            type: "Online",
            status: "accepted",
            payment: "verified",
            items: [
                { name: "Premium Rose Bouquet", quantity: 2, price: 1600 }
            ],
            address: "321 Blossom Rd, Taguig",
            rider: null,
            contact: "09215678901"
        },
        {
            id: "ORD-00119",
            customer: "Michael Tan",
            store: "Sunflower Central",
            date: "2024-12-01 01:30 PM",
            amount: 2100,
            type: "Walk-in",
            status: "delivered",
            payment: "cash",
            items: [
                { name: "Sunflower Basket", quantity: 1, price: 1500 },
                { name: "Chocolate", quantity: 2, price: 300 }
            ],
            address: "Store Pickup",
            rider: null,
            contact: "09226789012"
        },
        {
            id: "ORD-00118",
            customer: "Lisa Wong",
            store: "Orchid Oasis",
            date: "2024-11-30 09:15 AM",
            amount: 4800,
            type: "Online",
            status: "canceled",
            payment: "refunded",
            items: [
                { name: "Orchid Collection", quantity: 3, price: 1600 }
            ],
            address: "654 Gardenia St, Mandaluyong",
            rider: null,
            contact: "09237890123"
        }
    ];

    // State management
    let currentPage = 1;
    let pageSize = 25;
    let filteredOrders = [...mockOrders];
    let totalOrders = mockOrders.length;

    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
        loadStats();
        populateStoreFilter();
        loadOrders();
        setupEventListeners();
    });

    function loadStats() {
        const today = new Date().toISOString().split('T')[0];
        const todayOrders = mockOrders.filter(order => order.date.includes('2024-12-06')).length;
        const pendingOrders = mockOrders.filter(order => ['pending', 'accepted', 'preparing'].includes(order.status)).length;
        const totalRevenue = mockOrders.reduce((sum, order) => sum + order.amount, 0);

        document.getElementById('totalOrders').textContent = totalOrders;
        document.getElementById('todayOrders').textContent = todayOrders;
        document.getElementById('pendingOrders').textContent = pendingOrders;
        document.getElementById('totalRevenue').textContent = `₱${totalRevenue.toLocaleString()}`;
    }

    function populateStoreFilter() {
        const storeFilter = document.getElementById('storeFilter');
        mockStores.forEach(store => {
            const option = document.createElement('option');
            option.value = store.id;
            option.textContent = store.name;
            storeFilter.appendChild(option);
        });
    }

    function loadOrders() {
        const tableBody = document.getElementById('ordersTableBody');
        tableBody.innerHTML = '';

        // Calculate pagination
        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = startIndex + pageSize;
        const pageOrders = filteredOrders.slice(startIndex, endIndex);

        if (pageOrders.length === 0) {
            tableBody.innerHTML = `
                <tr>
                    <td colspan="9" style="text-align: center; padding: 3rem;">
                        <div class="empty-state-icon">
                            <i class="ri-shopping-bag-line"></i>
                        </div>
                        <h3 style="margin-bottom: 0.5rem; color: var(--text);">No Orders Found</h3>
                        <p style="color: var(--text-light);">Try changing your filters</p>
                    </td>
                </tr>
            `;
        } else {
            pageOrders.forEach(order => {
                const row = document.createElement('tr');
                
                // Status badge
                let statusBadge = '';
                switch(order.status) {
                    case 'pending':
                        statusBadge = '<span class="status-badge status-pending">Pending</span>';
                        break;
                    case 'accepted':
                        statusBadge = '<span class="status-badge status-pending">Accepted</span>';
                        break;
                    case 'preparing':
                        statusBadge = '<span class="status-badge status-pending">Preparing</span>';
                        break;
                    case 'on_delivery':
                        statusBadge = '<span class="status-badge status-active">On Delivery</span>';
                        break;
                    case 'delivered':
                        statusBadge = '<span class="status-badge status-completed">Delivered</span>';
                        break;
                    case 'canceled':
                        statusBadge = '<span class="status-badge status-cancelled">Canceled</span>';
                        break;
                }

                // Payment status
                let paymentStatus = '';
                switch(order.payment) {
                    case 'pending':
                        paymentStatus = '<span style="color: #b7950b;">Pending</span>';
                        break;
                    case 'verified':
                    case 'paid':
                        paymentStatus = '<span style="color: var(--sage-green);">Paid</span>';
                        break;
                    case 'cash':
                        paymentStatus = '<span style="color: var(--sage-green);">Cash</span>';
                        break;
                    case 'refunded':
                        paymentStatus = '<span style="color: #c62828;">Refunded</span>';
                        break;
                }

                row.innerHTML = `
                    <td><strong>${order.id}</strong></td>
                    <td>${order.customer}</td>
                    <td>${order.store}</td>
                    <td>${order.date}</td>
                    <td><strong>₱${order.amount.toLocaleString()}</strong></td>
                    <td>${order.type}</td>
                    <td>${statusBadge}</td>
                    <td>${paymentStatus}</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <button class="btn btn-outline" onclick="viewOrderDetails('${order.id}')" style="padding: 4px 12px; font-size: 12px;">
                                <i class="ri-eye-line"></i>
                            </button>
                            ${order.status === 'pending' ? `
                                <button class="btn btn-outline" onclick="updateOrderStatus('${order.id}', 'accepted')" style="padding: 4px 12px; font-size: 12px; color: var(--sage-green);">
                                    <i class="ri-check-line"></i>
                                </button>
                            ` : ''}
                            ${order.status === 'on_delivery' ? `
                                <button class="btn btn-outline" onclick="updateOrderStatus('${order.id}', 'delivered')" style="padding: 4px 12px; font-size: 12px; color: var(--sage-green);">
                                    <i class="ri-truck-line"></i>
                                </button>
                            ` : ''}
                        </div>
                    </td>
                `;
                tableBody.appendChild(row);
            });
        }

        updatePagination();
    }

    function setupEventListeners() {
        // Filter changes
        document.getElementById('storeFilter').addEventListener('change', applyFilters);
        document.getElementById('statusFilter').addEventListener('change', applyFilters);
        document.getElementById('dateFilter').addEventListener('change', applyFilters);
        document.getElementById('pageSize').addEventListener('change', function() {
            pageSize = parseInt(this.value);
            currentPage = 1;
            loadOrders();
        });

        // Pagination buttons
        document.getElementById('prevPage').addEventListener('click', () => {
            if (currentPage > 1) {
                currentPage--;
                loadOrders();
            }
        });

        document.getElementById('nextPage').addEventListener('click', () => {
            const totalPages = Math.ceil(filteredOrders.length / pageSize);
            if (currentPage < totalPages) {
                currentPage++;
                loadOrders();
            }
        });

        // Search input
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchOrders();
            }
        });
    }

    function applyFilters() {
        const storeId = document.getElementById('storeFilter').value;
        const status = document.getElementById('statusFilter').value;
        const dateRange = document.getElementById('dateFilter').value;

        filteredOrders = mockOrders.filter(order => {
            let matches = true;

            // Store filter
            if (storeId) {
                const store = mockStores.find(s => s.id == storeId);
                matches = matches && order.store === store.name;
            }

            // Status filter
            if (status) {
                matches = matches && order.status === status;
            }

            // Date filter (simplified for demo)
            if (dateRange === 'today') {
                matches = matches && order.date.includes('2024-12-06');
            } else if (dateRange === 'yesterday') {
                matches = matches && order.date.includes('2024-12-05');
            } else if (dateRange === 'week') {
                // Last 7 days logic would go here
            }

            return matches;
        });

        currentPage = 1;
        loadOrders();
        updateStats();
    }

    function searchOrders() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        
        if (!searchTerm) {
            filteredOrders = [...mockOrders];
        } else {
            filteredOrders = mockOrders.filter(order => 
                order.id.toLowerCase().includes(searchTerm) ||
                order.customer.toLowerCase().includes(searchTerm) ||
                order.store.toLowerCase().includes(searchTerm)
            );
        }

        currentPage = 1;
        loadOrders();
        updateStats();
    }

    function clearFilters() {
        document.getElementById('storeFilter').value = '';
        document.getElementById('statusFilter').value = '';
        document.getElementById('dateFilter').value = 'month';
        document.getElementById('searchInput').value = '';
        
        filteredOrders = [...mockOrders];
        currentPage = 1;
        loadOrders();
        updateStats();
    }

    function updateStats() {
        const today = new Date().toISOString().split('T')[0];
        const todayOrders = filteredOrders.filter(order => order.date.includes('2024-12-06')).length;
        const pendingOrders = filteredOrders.filter(order => ['pending', 'accepted', 'preparing'].includes(order.status)).length;
        const totalRevenue = filteredOrders.reduce((sum, order) => sum + order.amount, 0);

        document.getElementById('totalOrders').textContent = filteredOrders.length;
        document.getElementById('todayOrders').textContent = todayOrders;
        document.getElementById('pendingOrders').textContent = pendingOrders;
        document.getElementById('totalRevenue').textContent = `₱${totalRevenue.toLocaleString()}`;
    }

    function updatePagination() {
        const totalPages = Math.ceil(filteredOrders.length / pageSize);
        const prevBtn = document.getElementById('prevPage');
        const nextBtn = document.getElementById('nextPage');

        document.getElementById('currentPage').textContent = currentPage;
        document.getElementById('totalPages').textContent = totalPages;

        prevBtn.disabled = currentPage <= 1;
        nextBtn.disabled = currentPage >= totalPages;
    }

    function viewOrderDetails(orderId) {
        const order = mockOrders.find(o => o.id === orderId);
