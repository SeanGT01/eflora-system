                <div>
                    <div style="font-weight: 500;">${item.name}</div>
                    <div style="font-size: 12px; color: var(--text-light);">Quantity: ${item.quantity}</div>
                </div>
                <div style="font-weight: 600;">₱${(item.price * item.quantity).toLocaleString()}</div>
            </div>
        `).join('');

        content.innerHTML = `
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
                <div>
                    <div class="form-group">
                        <label class="form-label">Order ID</label>
                        <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md); font-weight: 600;">
                            ${order.id}
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Customer</label>
                        <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md);">
                            ${order.customer}
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Contact</label>
                        <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md);">
                            ${order.contact}
                        </div>
                    </div>
                </div>
                
                <div>
                    <div class="form-group">
                        <label class="form-label">Store</label>
                        <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md);">
                            ${order.store}
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Order Type</label>
                        <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md);">
                            ${order.type}
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Order Date</label>
                        <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md);">
                            ${order.date}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="form-group">
                <label class="form-label">Delivery Address</label>
                <div style="padding: 0.875rem; background: rgba(182, 110, 121, 0.05); border-radius: var(--radius-md); min-height: 60px;">
                    ${order.address}
                </div>
            </div>
            
            <div class="form-group">
                <label class="form-label">Order Items</label>
                ${itemsHtml}
                <div style="display: flex; justify-content: space-between; padding: 1rem; background: linear-gradient(135deg, rgba(182, 110, 121, 0.1), rgba(157, 193, 131, 0.1)); border-radius: var(--radius-md); margin-top: 1rem;">
                    <div style="font-weight: 600; font-size: 18px;">Total Amount</div>
                    <div style="font-weight: 700; font-size: 24px; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        ₱${order.amount.toLocaleString()}
                    </div>
                </div>
            </div>
            
            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button class="btn btn-primary" onclick="printOrder('${order.id}')">
                    <i class="ri-printer-line"></i>
                    Print Receipt
                </button>
                <button class="btn btn-outline" onclick="closeOrderDetails()">
                    Close
                </button>
            </div>
        `;

        modal.style.display = 'flex';
    }

    function closeOrderDetails() {
        document.getElementById('orderDetailsModal').style.display = 'none';
    }

    function updateOrderStatus(orderId, newStatus) {
        if (confirm(`Are you sure you want to update order ${orderId} to ${newStatus}?`)) {
            // Here you would typically make an API call to update the status
            alert(`Order ${orderId} status updated to ${newStatus}`);
            // Refresh orders
            refreshOrders();
        }
    }

    function printOrder(orderId) {
        alert(`Printing receipt for order ${orderId}`);
        // Print functionality would go here
    }

    function exportOrders() {
        alert('Exporting orders to CSV...');
        // Export functionality would go here
    }

    function refreshOrders() {
        // Simulate loading
        const tableBody = document.getElementById('ordersTableBody');
        tableBody.innerHTML = `
            <tr id="loadingRow">
                <td colspan="9" style="text-align: center; padding: 3rem;">
                    <div class="loading-spinner" style="margin: 0 auto;"></div>
